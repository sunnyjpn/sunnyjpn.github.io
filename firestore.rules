rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ------------------------------------------------------------------
    // users/{uid}
    //   - 誰でも読み取り可（世界ランキング／フレンドのプロフィール表示のため）
    //   - 書き込みは本人のみ
    //   - 主要フィールドの型・範囲・改ざん防止（記録の巻き戻し禁止など）を検証
    //   - friends / friendRequests はサブコレクションで別管理するため、
    //     ここでは親ドキュメントへのフィールドとしての friends 書き込みは許可しない
    // ------------------------------------------------------------------
    match /users/{uid} {

      function isOwner() {
        return request.auth != null && request.auth.uid == uid;
      }

      function afterData() {
        return request.resource.data;
      }

      function beforeData() {
        return resource.data;
      }

      function isNewDoc() {
        return resource == null;
      }

      // 統計フィールド（bestScore / attemptCount / totalTimeSum / recentHistory /
      // recentRawMs / suspicious / createdAt / updatedAt）は、
      // Cloud Functions（startRound / submitScore）内の Admin SDK からのみ書き込む。
      // Admin SDK はセキュリティルールの対象外のため、ここで許可する必要はない。
      // むしろクライアントSDKからは絶対にこれらのフィールドへ触れさせない
      // （直接書き込みができてしまうと、レート制限もプレイ実在性の検証も
      //   一切通さずにランキングを荒らせてしまうため）。
      function onlyTouchesClientFields(before) {
        return request.resource.data.diff(before).affectedKeys().hasOnly(['nickname', 'friendCode']);
      }

      // ニックネームは16文字以内の文字列（未設定なら空文字も許可）
      function nicknameIsValid() {
        return !('nickname' in afterData())
          || (afterData().nickname is string && afterData().nickname.size() <= 16);
      }

      // friendCode は SUN-XXXXXX 形式の文字列。
      // 一度発行したら書き換え不可（friendCodes コレクションとの整合性を保つため）
      function friendCodeIsValid() {
        return !('friendCode' in afterData())
          || (
            afterData().friendCode is string
            && afterData().friendCode.matches('^SUN-[A-Z0-9]{6}$')
            && (
              isNewDoc()
              || !('friendCode' in beforeData())
              || afterData().friendCode == beforeData().friendCode
            )
          );
      }

      allow read: if true;

      // クライアント（ブラウザ）からの直接書き込みは nickname / friendCode のみ許可。
      // スコア（bestScore 等）は Cloud Functions 経由でしか更新できない。
      allow create: if isOwner()
        && request.resource.data.keys().hasOnly(['nickname', 'friendCode'])
        && nicknameIsValid()
        && friendCodeIsValid();

      allow update: if isOwner()
        && onlyTouchesClientFields(resource.data)
        && nicknameIsValid()
        && friendCodeIsValid();

      allow delete: if false;

      // ----------------------------------------------------------------
      // users/{uid}/friendRequests/{fromUid}
      //   - 受信者(uid)本人のみ閲覧・削除（承認/拒否）できる
      //   - 送信は fromUid 本人のみが、自分の uid をキーにしたリクエストとして作成できる
      //   - 既にリクエストが存在する場合は上書き不可（連投・改ざん防止）
      //   - 送信できるフィールドを厳密に制限する
      // ----------------------------------------------------------------
      match /friendRequests/{fromUid} {

        function requestFieldsAreValid() {
          return request.resource.data.keys().hasOnly(['fromUid', 'fromNickname', 'fromCode', 'createdAt', 'status'])
            && request.resource.data.fromUid == fromUid
            && request.resource.data.fromUid == request.auth.uid
            && (!('fromNickname' in request.resource.data)
                || (request.resource.data.fromNickname is string && request.resource.data.fromNickname.size() <= 16))
            && (!('fromCode' in request.resource.data)
                || (request.resource.data.fromCode is string && request.resource.data.fromCode.size() <= 16));
        }

        allow read, delete: if request.auth != null && request.auth.uid == uid;

        allow create: if request.auth != null
          && request.auth.uid == fromUid
          && fromUid != uid
          && resource == null
          && requestFieldsAreValid();

        allow update: if false;
      }

      // ----------------------------------------------------------------
      // users/{uid}/friends/{friendUid}
      //   - 相互フレンド関係。承認処理で自分側・相手側の双方に1件ずつ作成される
      //   - 作成・削除は「uid本人」または「friendUid本人」のいずれかが行える
      //     （承認した側が相手のフレンドリストにも書き込む必要があるため）
      //   - 更新（フィールド改変）は不可。関係の有無だけを表すシンプルな存在フラグとして扱う
      // ----------------------------------------------------------------
      match /friends/{friendUid} {

        function friendFieldsAreValid() {
          return request.resource.data.keys().hasOnly(['since'])
            && friendUid != uid;
        }

        allow read: if request.auth != null && request.auth.uid == uid;

        allow create: if request.auth != null
          && (request.auth.uid == uid || request.auth.uid == friendUid)
          && friendFieldsAreValid();

        allow delete: if request.auth != null
          && (request.auth.uid == uid || request.auth.uid == friendUid);

        allow update: if false;
      }

      // ----------------------------------------------------------------
      // users/{uid}/rounds/{roundId}
      //   - Cloud Functions（startRound / submitScore）専用のワンタイム
      //     トークン置き場。クライアントSDKからは読み書き一切不可。
      //     Admin SDK はルールの対象外のため、Functions側からは常に操作できる。
      // ----------------------------------------------------------------
      match /rounds/{roundId} {
        allow read, write: if false;
      }
    }

    // ------------------------------------------------------------------
    // friendCodes/{code}
    //   - フレンドID → uid の逆引き用。誰でも読み取り可（ID検索のため）
    //   - 作成は「本人が」「自分の uid に紐づくコードとして」1回だけ発行できる
    //     （users/{uid}.friendCode が未設定の場合のみ発行を許可し、二重発行を防止）
    //   - 更新・削除は一切不可（IDの乗っ取り・使い回しを防止）
    // ------------------------------------------------------------------
    match /friendCodes/{code} {

      function codeFormatIsValid() {
        return code.matches('^SUN-[A-Z0-9]{6}$');
      }

      function ownerHasNoCodeYet() {
        let userDoc = get(/databases/$(database)/documents/users/$(request.auth.uid));
        return !userDoc.data.keys().hasAny(['friendCode'])
          || userDoc.data.friendCode == null
          || userDoc.data.friendCode == '';
      }

      allow read: if true;

      allow create: if request.auth != null
        && request.resource.data.keys().hasOnly(['uid', 'createdAt'])
        && request.resource.data.uid == request.auth.uid
        && codeFormatIsValid()
        && ownerHasNoCodeYet();

      allow update, delete: if false;
    }
  }
}
