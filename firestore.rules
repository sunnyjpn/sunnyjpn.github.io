rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ------------------------------------------------------------------
    // users/{uid}
    //   - 誰でも読み取り可（世界ランキング表示のため）
    //   - 書き込みは本人のみ
    //   - 主要フィールドの型・範囲・改ざん防止（記録の巻き戻し禁止など）を検証
    // ------------------------------------------------------------------
    match /users/{uid} {

      function isOwner() {
        return request.auth != null && request.auth.uid == uid;
      }

      function afterData() {
        return request.resource.data;
      }

      function beforeData() {
        return resource.data;
      }

      function isNewDoc() {
        return resource == null;
      }

      // 統計フィールド（bestScore / attemptCount / totalTimeSum / recentHistory /
      // recentRawMs / suspicious / tooFastStreak / bannedUntil /
      // photoURL / createdAt / updatedAt）は、Cloud Functions内の Admin SDK からのみ書き込む。
      // photoURL は syncProfile（Admin SDK）が、検証済みIDトークンのクレームから設定する。
      // クライアントが任意の画像URLを自称できてしまうと、フィッシングや不快な画像の
      // 埋め込みに悪用され得るため、クライアントSDKからの直接書き込みは対象外のままにする。
      // Admin SDK はセキュリティルールの対象外のため、ここで許可する必要はない。
      // むしろクライアントSDKからは絶対にこれらのフィールドへ触れさせない
      // （直接書き込みができてしまうと、レート制限もプレイ実在性の検証も
      //   一切通さずにランキングを荒らせてしまうため）。
      function onlyTouchesClientFields(before) {
        return request.resource.data.diff(before).affectedKeys().hasOnly(['nickname']);
      }

      // ニックネームは16文字以内の文字列（未設定なら空文字も許可）
      function nicknameIsValid() {
        return !('nickname' in afterData())
          || (afterData().nickname is string && afterData().nickname.size() <= 16);
      }

      allow read: if true;

      // クライアント（ブラウザ）からの直接書き込みは nickname のみ許可。
      // スコア等は Cloud Functions 経由でしか更新できない。
      allow create: if isOwner()
        && request.resource.data.keys().hasOnly(['nickname'])
        && nicknameIsValid();

      allow update: if isOwner()
        && onlyTouchesClientFields(resource.data)
        && nicknameIsValid();

      allow delete: if false;

      // ----------------------------------------------------------------
      // users/{uid}/rounds/{roundId}
      //   - Cloud Functions（startRound / submitScore）専用のワンタイム
      //     トークン置き場。クライアントSDKからは読み書き一切不可。
      //     Admin SDK はルールの対象外のため、Functions側からは常に操作できる。
      // ----------------------------------------------------------------
      match /rounds/{roundId} {
        allow read, write: if false;
      }
    }
  }
}
